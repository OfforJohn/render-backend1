// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}



model User {
  id                Int        @id @default(autoincrement())
  email             String     @unique
  name              String
  phoneNumber       String?    // <-- Add this line
  profilePicture    String     @db.Text
  about             String     @default("")
  sentMessages      Messages[] @relation("sentMessages")
  recievedMessages  Messages[] @relation("recievedMessages")
}


model Messages {
  id Int @id @default(autoincrement())
  sender User @relation("sentMessages",fields:[senderId],references: [id])
  senderId Int
  reciever User @relation("recievedMessages", fields: [recieverId],references: [id])
  recieverId Int
  type String @default("text")
  message String
  messageStatus String @default("sent")
  createdAt DateTime @default(now())
}

model BotReply {
  id      Int    @id @default(autoincrement())
  content String
}

model WhatsAppProfile {
  id          Int      @id @default(autoincrement())
  phoneNumber String   @unique
  pictureUrl  String?  @db.Text
  isValid     Boolean  @default(false)
  status      String   @default("pending") // pending, valid, invalid, error
  jobId       String?  // to group batch jobs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProfileJob {
  id            String   @id @default(uuid())
  totalCount    Int      @default(0)
  processedCount Int     @default(0)
  status        String   @default("pending") // pending, processing, completed, failed
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}




